# Optional: enable CLI LLM agent (`run` command)
# OPENAI_API_KEY=sk-...
# BROWSER_MCP_AGENT_MODEL=gpt-4o-mini

# Browser MCP server configuration

# WebSocket port shared between the Node server and the Chrome extension.
# Update the extension popup if you change this value.
BROWSER_MCP_WS_PORT=58338

# Timeout (in milliseconds) for extension responses before the server aborts
# a tool call.
BROWSER_MCP_TIMEOUT_MS=30000

# Enable to surface verbose logging from the server.
BROWSER_MCP_DEBUG=false

# Remote debugging port used when auto-launching Chrome.
BROWSER_MCP_DEBUG_PORT=9222

# Optional: point to an existing Chrome/Chromium binary and skip auto-install.
# BROWSER_MCP_CHROME_PATH=/Applications/Google Chrome.app/Contents/MacOS/Google Chrome

# Optional: skip launching Chrome automatically and attach to a manually-loaded extension instead.
# BROWSER_MCP_SKIP_LAUNCH=false

# Optional overrides for where auto-installed artifacts are stored.
# BROWSER_MCP_PROFILE_DIR=~/.local/browser-mcp/profile
# BROWSER_MCP_DATA_DIR=~/.local/browser-mcp
# BROWSER_MCP_BIN_DIR=~/.local/bin

# Optional: load a different unpacked extension directory.
# BROWSER_MCP_EXTENSION_DIR=/path/to/extension
