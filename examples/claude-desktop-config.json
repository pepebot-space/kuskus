{
  "_comment": "Add the 'kuskus' entry inside mcpServers in your Claude Desktop config.",
  "_config_path_macos": "~/Library/Application Support/Claude/claude_desktop_config.json",
  "_config_path_windows": "%APPDATA%\\Claude\\claude_desktop_config.json",
  "mcpServers": {
    "kuskus": {
      "command": "npx",
      "args": ["-y", "@porcupine/kuskus", "mcp"],
      "env": {
        "CDP_URL": "ws://localhost:9222",
        "LOG_LEVEL": "warn"
      }
    }
  }
}
